# Database
POSTGRES_URL=postgresql://raguser:ragpass@localhost:5432/ragdemo

# Google Gemini (required — get a free key at https://aistudio.google.com)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-3.1-flash-lite

# API ports
HYBRID_API_PORT=8001
ANSWER_API_PORT=8002

# Internal service URLs (change only if you modify ports above)
HYBRID_API_URL=http://localhost:8001
SEARCH_URL=http://localhost:8001/search_hybrid

# Optional: Groq (alternative LLM provider)
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Ollama (local inference — slow on CPU-only hardware)
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=phi3:3.8b
